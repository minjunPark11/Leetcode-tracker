# Supabase 프로젝트 설정 (대시보드 > Project Settings > API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 단일 계정 자동 로그인용 자격증명
# Supabase 대시보드 > Authentication > Users 에서 계정을 1개 만든 뒤,
# 그 이메일/비밀번호를 아래에 입력하세요. 앱이 시작 시 자동으로 로그인합니다.
# (값을 비워두면 인증 없이 로컬(Dexie)만으로 동작합니다.)
VITE_APP_USER_EMAIL=
VITE_APP_USER_PASSWORD=
